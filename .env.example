# ── JARVIS configuration ────────────────────────────────────────────
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.

# The Claude model JARVIS thinks with. Swappable: claude-opus-4-8 (default),
# claude-sonnet-4-6, claude-haiku-4-5. See JARVIS/System/ARCHITECTURE.md.
JARVIS_MODEL=claude-opus-4-8

# Which brain implementation to use: agent-sdk (default) | api (not yet built)
JARVIS_BRAIN=agent-sdk

# Local ports (loopback only)
JARVIS_AGENT_PORT=4777
JARVIS_VOICE_PORT=4778

# Absolute path to the JARVIS-owned folder inside the Obsidian vault
JARVIS_VAULT_PATH=/Users/fidelakilah/Documents/JARVIS/JARVIS VAULT/JARVIS

# Voice pipeline: whisper size (tiny/base/small/medium — bigger = more accurate,
# slower), language, Piper voice name, wake-word sensitivity 0–1 (lower = more
# sensitive, more false triggers)
JARVIS_WHISPER_MODEL=small
JARVIS_LANGUAGE=en
JARVIS_TTS_VOICE=en_GB-alan-medium
JARVIS_WAKE_THRESHOLD=0.5

# Long-lived Claude subscription token. Generate with:  claude setup-token
# (starts with sk-ant-oat01-…). This keeps JARVIS on the Max plan — no API billing.
CLAUDE_CODE_OAUTH_TOKEN=
